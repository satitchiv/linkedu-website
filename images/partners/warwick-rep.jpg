        background-color: black;
        -webkit-transition: all 0.3s ease-out;
        transition: all 0.3s ease-out;
        color: #fff;
        border-color: black;
        } .fluentform_wrapper_1 .ff-el-group input[type=radio]:after {
        border-radius: 50%;
        font-size: 10px;
        padding-top: 1px;

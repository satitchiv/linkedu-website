jQuery(document).ready(function($) {
    $.fn.dataTable.ext.type.order['mixed-rank-pre'] = function (data) {
        // Handle 'n/a' as the lowest value
        if (data === 'n/a' || data === 'NA') {
            return Infinity;
        }

        // Handle ranges by averaging the numbers
        if (data.includes('-')) {
            var range = data.split('-').map(Number);
            return (range[0] + range[1]) / 2;
        }

        // Otherwise, parse the number
        return parseFloat(data) || 0;
    };

    $('.school-ranking-table').DataTable({
        "info": false,
        "searching": false,
        "pageLength": 50,
        "columnDefs": [
            { "type": "mixed-rank", "targets": [0, 1] } // Apply to the first and second columns (Rank and World Ranking)
        ],
        "language": {
            "lengthMenu": "顯示 _MENU_ 間院校",
            "paginate": {
                "first": "First page",
                "last": "Last page",
                "next": "下一頁",
                "previous": "上一頁",
            }
        }
    });
});



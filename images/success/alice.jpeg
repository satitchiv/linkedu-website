jQuery(document).ready(function($) {
    $(window).scroll(function () {
        // Check scroll position
        if ($(this).scrollTop() > 900) {
            $('.event__footer-apply-wrap').addClass('colorChange');
            $('.tf-contact-button').addClass('colorChange');
        } else {
            $('.event__footer-apply-wrap').removeClass('colorChange');
            $('.tf-contact-button').removeClass('colorChange');
        }

        // Check if .footer-hero is in the viewport and remove the class
        const footerHeroTop = $('.footer-hero').offset().top; // Get .footer-hero position
        const scrollTop = $(this).scrollTop(); // Get current scroll position
        const windowHeight = $(window).height(); // Get window height

        if (scrollTop + windowHeight >= footerHeroTop) {
            // .footer-hero is visible in the viewport
            $('.tf-contact-button').removeClass('colorChange');
        }
    });
});


    // A function to get the cookie value or create it if it doesn't exist
    function getCookie(name) {
        // Special handling for _ga cookie
        if (name === '_ga') {
            // Look for the _ga cookie
            const cookies = document.cookie.split(';');
            for (let cookie of cookies) {
                cookie = cookie.trim();
                if (cookie.startsWith('_ga=')) {
                    // Return the entire cookie value
                    return cookie.substring(4);
                }
            }
            // If not found, generate a random one
            var randomValue = Math.random().toString(36).substring(2, 15);
            document.cookie = `_ga=${randomValue}; expires=Fri, 31 Dec 9999 23:59:59 GMT; path=/`;
            return randomValue;
        }
        
        // Original logic for other cookies
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) {
            const cookieValue = parts.pop().split(';').shift();
            if (cookieValue && cookieValue.trim() !== '') {
                return cookieValue;
            }
        }
        
        // Generate new cookie if not found
        var randomValue = Math.random().toString(36).substring(2, 14);
        document.cookie = `${name}=${randomValue}; expires=Fri, 31 Dec 9999 23:59:59 GMT; path=/`;
        return randomValue;
    }

    // Initialize Google Analytics
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    // Send the user properties to Google Analytics
    gtag('set', 'user_properties', {
        'capsuite_sid': getCookie("_ga"),
        'capsuite_apid': getCookie("_ap_id"),
    });

    window.getCookie = getCookie;
    </script>
    

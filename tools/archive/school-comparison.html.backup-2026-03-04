                const name = SCHOOL_NAMES[i];
                const fee = Math.floor(Math.random() * (50000 - 25000 + 1) + 25000); // £25,000 - £50,000
                const type = SCHOOL_TYPES[Math.floor(Math.random() * SCHOOL_TYPES.length)];
                const region = UK_REGIONS[Math.floor(Math.random() * UK_REGIONS.length)];
                const alevelPercentage = Math.floor(Math.random() * (80 - 20 + 1) + 20); // 20% - 80% A*-B
                const numSports = Math.floor(Math.random() * (15 - 5 + 1) + 5); // 5-15 sports
                const selectedSports = [];
                const availableSports = [...SPORTS_LIST];
                for (let j = 0; j < numSports; j++) {
                    if (availableSports.length === 0) break;
                    const randomIndex = Math.floor(Math.random() * availableSports.length);
                    selectedSports.push(availableSports.splice(randomIndex, 1)[0]);
                }
                const scholarshipStatus = Math.random() > 0.6 ? "Yes" : "No"; // ~40% have scholarships
                const scholarshipNote = scholarshipStatus === "Yes" ? "Academic, Art, Drama, Music, Sport and All-Rounder scholarships available." : "";

                schools.push({
                    id: `school-${i + 1}`,
                    name,
                    fee,
                    type,
                    region,
                    alevelPercentage,
                    sports: selectedSports,
                    scholarshipStatus,
                    scholarshipNote
                });
            }
            return schools;
        }

        const SCHOOLS = generateSchoolsData();
        // --- END SCHOOLS DATA ---


        function setLanguage(lang) {
            currentLang = lang;
            localStorage.setItem('linkedU_lang', lang);

            // Update document title
            const titleElement = document.querySelector('title');
            if (titleElement) {
                const enTitleKey = titleElement.getAttribute('data-en');
                if (translations[lang] && translations[lang][enTitleKey]) {
                    document.title = translations[lang][enTitleKey];
                } else {
                    document.title = enTitleKey; // Fallback to English if translation missing
                }
            }

            document.querySelectorAll('[data-en]').forEach(element => {
                const key = element.getAttribute('data-en');
                if (translations[lang] && translations[lang][key]) {
                    element.textContent = translations[lang][key];
                } else {
                    element.textContent = key; // Fallback to English if translation missing
                }
            });

            langButtons.forEach(button => {
                button.classList.remove('active');
                if (button.dataset.lang === lang) {
                    button.classList.add('active');
                }
            });

            // Update dropdown placeholder and re-populate options
            populateDropdowns();
            // Re-render comparison table and chart to update school names and chart labels
            updateComparison();
        }

        langButtons.forEach(button => {
            button.addEventListener('click', () => setLanguage(button.dataset.lang));
        });

        // Initialize language on load
        document.addEventListener('DOMContentLoaded', () => {
            setLanguage(currentLang);
        });
        // --- END LANGUAGE TOGGLE ---


        // --- SCHOOL COMPARISON TOOL ---
        const schoolSelects = [
            document.getElementById('school1'),
            document.getElementById('school2'),
            document.getElementById('school3')
        ];
        const comparisonTable = document.getElementById('comparisonTable');
        const radarChartCanvas = document.getElementById('radarChart');
        let radarChartInstance = null;

        const regionScores = {
            "London": 1.0, "South East": 0.9, "South West": 0.8, "East of England": 0.7,
            "West Midlands": 0.6, "East Midlands": 0.5, "North West": 0.4, "North East": 0.3,
            "Yorkshire and the Humber": 0.5, "Scotland": 0.2, "Wales": 0.2
        };

        const typeScores = {
            "Co-educational": 1.0, "Boys": 0.8, "Girls": 0.8
        };

        // Pre-calculate min/max for normalization
        const fees = SCHOOLS.map(s => s.fee);
        const alevelPercentages = SCHOOLS.map(s => s.alevelPercentage);
        const sportsCounts = SCHOOLS.map(s => s.sports.length);
        const typeScoreValues = Object.values(typeScores);
        const regionScoreValues = Object.values(regionScores);

        const minFee = Math.min(...fees);
        const maxFee = Math.max(...fees);
        const minAlevel = Math.min(...alevelPercentages);
        const maxAlevel = Math.max(...alevelPercentages);
        const minSports = Math.min(...sportsCounts);
        const maxSports = Math.max(...sportsCounts);
        const minTypeScore = Math.min(...typeScoreValues);
        const maxTypeScore = Math.max(...typeScoreValues);
        const minRegionScore = Math.min(...regionScoreValues);
        const maxRegionScore = Math.max(...regionScoreValues);

        function normalize(value, min, max) {
            if (min === max) return 50; // Avoid division by zero, return middle value
            return ((value - min) / (max - min)) * 100;
        }

        function populateDropdowns() {
            schoolSelects.forEach(select => {
                const currentSelected = select.value; // Store current selection
                select.innerHTML = `<option value="">${translations[currentLang]["No school selected"]}</option>`; // Placeholder
                SCHOOLS.sort((a, b) => a.name.localeCompare(b.name)).forEach(school => {
                    const option = document.createElement('option');
                    option.value = school.id;
                    option.textContent = school.name;
                    select.appendChild(option);
                });
                select.value = currentSelected; // Restore current selection
            });
            updateDropdownOptions(); // Also update options to disable already selected ones
        }

        function getSelectedSchools() {
            const selectedIds = schoolSelects.map(select => select.value).filter(id => id);
            return selectedIds.map(id => SCHOOLS.find(s => s.id === id));
        }

        function updateDropdownOptions() {
            const selectedIds = schoolSelects.map(select => select.value);

            schoolSelects.forEach(currentSelect => {
                const currentSelected = currentSelect.value;
                currentSelect.innerHTML = `<option value="">${translations[currentLang]["No school selected"]}</option>`;

                SCHOOLS.sort((a, b) => a.name.localeCompare(b.name)).forEach(school => {
                    const option = document.createElement('option');
                    option.value = school.id;
                    option.textContent = school.name;

                    // Disable if already selected in another dropdown, unless it's the current selection
                    if (selectedIds.includes(school.id) && school.id !== currentSelected) {
                        option.disabled = true;
                    }
                    currentSelect.appendChild(option);
                });
                currentSelect.value = currentSelected; // Restore current selection
            });
        }

        function updateComparison() {
            const selectedSchools = getSelectedSchools();
            renderComparisonTable(selectedSchools);
            renderRadarChart(selectedSchools);
            updateDropdownOptions(); // Update options after selection change
        }

        function renderComparisonTable(schools) {
            const headerRow = comparisonTable.querySelector('thead tr');
            const bodyRows = comparisonTable.querySelectorAll('tbody tr');

            // Clear previous school names and data
            headerRow.querySelectorAll('th:not(.feature-column)').forEach(th => th.textContent = '');
            bodyRows.forEach(row => {
                row.querySelectorAll('td:not(.feature-column)').forEach(td => {
                    td.textContent = '';
                    td.classList.remove('highlight-gold');
                });
            });

            if (schools.length === 0) {
                return;
            }

            // Populate school names in header
            schools.forEach((school, index) => {
                const th = headerRow.children[index + 1];
                if (th) th.textContent = school.name;
            });

            // Prepare data for comparison and highlighting
            const fees = schools.map(s => s.fee).filter(f => f !== undefined);
            const alevelPercentages = schools.map(s => s.alevelPercentage).filter(a => a !== undefined);
            const sportsCounts = schools.map(s => s.sports ? s.sports.length : 0);
            const scholarshipStatuses = schools.map(s => s.scholarshipStatus);

            const minFeeValue = fees.length > 0 ? Math.min(...fees) : undefined;
            const maxAlevelValue = alevelPercentages.length > 0 ? Math.max(...alevelPercentages) : undefined;
            const maxSportsCount = sportsCounts.length > 0 ? Math.max(...sportsCounts) : undefined;
            const hasScholarshipWinner = scholarshipStatuses.includes("Yes");

            // Populate table body
            schools.forEach((school, schoolIndex) => {
                const colIndex = schoolIndex + 1; // Column index in table

                // Fee
                const feeCell = bodyRows[0].children[colIndex];
                if (school.fee !== undefined) {
                    feeCell.textContent = `£${school.fee.toLocaleString()}`;
                    if (school.fee === minFeeValue && schools.filter(s => s.fee === minFeeValue).length === 1) {
                        feeCell.classList.add('highlight-gold');
                    }
                }

                // Type
                const typeCell = bodyRows[1].children[colIndex];
                if (school.type) typeCell.textContent = school.type;

                // Region
                const regionCell = bodyRows[2].children[colIndex];
                if (school.region) regionCell.textContent = school.region;

                // A-Level %
                const alevelCell = bodyRows[3].children[colIndex];
                if (school.alevelPercentage !== undefined) {
                    alevelCell.textContent = `${school.alevelPercentage}%`;
                    if (school.alevelPercentage === maxAlevelValue && schools.filter(s => s.alevelPercentage === maxAlevelValue).length === 1) {
                        alevelCell.classList.add('highlight-gold');
                    }
                }

                // Sports Offered
                const sportsCell = bodyRows[4].children[colIndex];
                if (school.sports && school.sports.length > 0) {
                    sportsCell.textContent = school.sports.join(', ');
                    if (school.sports.length === maxSportsCount && schools.filter(s => s.sports && s.sports.length === maxSportsCount).length === 1) {
                        sportsCell.classList.add('highlight-gold');
                    }
                } else {
                    sportsCell.textContent = translations[currentLang]["N/A"];
                }

                // Scholarship Status
                const scholarshipStatusCell = bodyRows[5].children[colIndex];
                if (school.scholarshipStatus) {
                    scholarshipStatusCell.textContent = school.scholarshipStatus;
                    if (school.scholarshipStatus === "Yes" && hasScholarshipWinner && schools.filter(s => s.scholarshipStatus === "Yes").length === 1) {
                        scholarshipStatusCell.classList.add('highlight-gold');
                    }
                }

                // Scholarship Note
                const scholarshipNoteCell = bodyRows[6].children[colIndex];
                if (school.scholarshipNote) {
                    scholarshipNoteCell.textContent = school.scholarshipNote;
                } else {
                    scholarshipNoteCell.textContent = translations[currentLang]["No note"];
                }
            });
        }

        function renderRadarChart(schools) {
            if (radarChartInstance) {
                radarChartInstance.destroy();
            }

            if (schools.length === 0) {
                radarChartCanvas.style.display = 'none';
                return;
            } else {
                radarChartCanvas.style.display = 'block';
            }

            const labels = [
                translations[currentLang]["Academic Performance (A-Level %)"],
                translations[currentLang]["Affordability (Fee)"],
                translations[currentLang]["Sports Variety"],
                translations[currentLang]["Scholarship Opportunities"],
                translations[currentLang]["School Type Preference"],
                translations[currentLang]["Regional Appeal"]
            ];

            const datasets = schools.map((school, index) => {
                const data = [];
                // 1. Academic Performance (A-Level %) - Higher is better
                data.push(normalize(school.alevelPercentage, minAlevel, maxAlevel));

                // 2. Affordability (Fee) - Lower is better, invert fee for normalization
                data.push(normalize(maxFee - school.fee, maxFee - maxFee, maxFee - minFee));

                // 3. Sports Variety (Count) - More sports is better
                data.push(normalize(school.sports.length, minSports, maxSports));

                // 4. Scholarship Opportunities - Yes=1, No=0
                data.push(school.scholarshipStatus === 'Yes' ? 100 : 0);

                // 5. School Type Preference (Co-educational=1, Boys=0.8, Girls=0.8)
                data.push(normalize(typeScores[school.type], minTypeScore, maxTypeScore));

                // 6. Regional Appeal (Score based on region)
                data.push(normalize(regionScores[school.region], minRegionScore, maxRegionScore));

                const colors = [
                    'rgba(27, 58, 92, 0.8)',  // Navy
                    'rgba(201, 168, 76, 0.8)', // Gold
                    'rgba(100, 100, 100, 0.8)' // Grey
                ];
                const borderColors = [
                    'rgba(27, 58, 92, 1)',
                    'rgba(201, 168, 76, 1)',
                    'rgba(100, 100, 100, 1)'
                ];

                return {
                    label: school.name,
                    data: data,
                    backgroundColor: colors[index % colors.length],
                    borderColor: borderColors[index % borderColors.length],
                    borderWidth: 2,
                    pointBackgroundColor: borderColors[index % borderColors.length],
                    pointBorderColor: '#fff',
                    pointHoverBackgroundColor: '#fff',
                    pointHoverBorderColor: borderColors[index % borderColors.length]
                };
            });

            radarChartInstance = new Chart(radarChartCanvas, {
                type: 'radar',
                data: {
                    labels: labels,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            labels: {
                                font: {
                                    family: 'Inter',
                                    size: 14
                                },
                                color: '#2D2D2D' /* Use actual hex value for --text */
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    label += Math.round(context.raw) + '%';
                                    return label;
                                }
                            },
                            titleFont: { family: 'Inter', weight: '600' },
                            bodyFont: { family: 'Inter' }
                        }
                    },
                    scales: {
                        r: {
                            angleLines: {
                                color: 'rgba(0, 0, 0, 0.1)'
                            },
                            grid: {
                                color: 'rgba(0, 0, 0, 0.1)'
                            },
                            pointLabels: {
                                font: {
                                    family: 'Inter',
                                    size: 13,
                                    weight: '600'
                                },
                                color: '#2D2D2D' /* Use actual hex value for --text */
                            },
                            suggestedMin: 0,
                            suggestedMax: 100,
                            ticks: {
                                display: false, // Hide the numerical ticks
                                beginAtZero: true,
                                font: {
                                    family: 'Inter'
                                }
                            }
                        }
                    }
                }
            });
        }

        // Event listeners for dropdowns
        schoolSelects.forEach(select => {
            select.addEventListener('change', updateComparison);
        });

        // Initial setup
        document.addEventListener('DOMContentLoaded', () => {
            populateDropdowns();
            updateComparison(); // Render initial empty state or pre-selected if any
        });
        // --- END SCHOOL COMPARISON TOOL ---
    </script>
